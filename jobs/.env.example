# Copy to .env (local) — never commit. Server .env is independent.
# This file documents every env var the pipeline reads. main.py loads .env
# via python-dotenv at startup; production cron sets env vars directly.

# --- Salary floor (consumed by filter.py) ----------------------------------
# Monthly USD. Conservative mid-ITS-I default below. JT sets the real floor
# in his local .env (never committed).
SALARY_FLOOR=8000

# --- Output path (consumed by main.py) -------------------------------------
# Where main.py writes the rendered results page. Relative paths resolve
# against the project root, not CWD. Absolute paths are honored as-is.
JOBS_OUTPUT_PATH=./output/index.html

# --- Page auth (consumed by server.py — Flask basic auth) ------------------
ADMIN_USER=admin
ADMIN_PASSWORD=

# --- USAJobs API (consumed by crawler/sources/usajobs.py) ------------------
# User-Agent must be your email per USAJobs TOS.
USAJOBS_USER_AGENT=
USAJOBS_API_KEY=

# --- Anthropic API (consumed by score_llm.py — Tier 2; not yet wired) ------
ANTHROPIC_API_KEY=

# --- Mail provider (consumed by notify.py — not yet wired). Pick ONE. ------
# Option A: Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
# Option B: SendGrid
SENDGRID_API_KEY=
# Option C: SMTP (Opalstack)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Where to send the "perfect fit" emails (consumed by notify.py).
NOTIFY_EMAIL=

# --- Scoring thresholds (consumed by future Tier-2 email gate) -------------
# Do not change without approval — locked by SPEC.md.
TIER1_EMAIL_THRESHOLD=80
TIER2_EMAIL_THRESHOLD=8
TIER2_TOP_N=10

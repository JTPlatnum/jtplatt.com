# Copy to .env (local) — never commit. Server .env is independent.

# Salary floor (monthly, USD). Set to JT's current ITS I monthly rate.
SALARY_FLOOR=7000

# Page auth
ADMIN_PASSWORD=change-me

# Anthropic API key for Tier 2 scoring
ANTHROPIC_API_KEY=

# Mail provider — pick ONE
# Option A: Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
# Option B: SendGrid
SENDGRID_API_KEY=
# Option C: SMTP (Opalstack)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Where to send the "perfect fit" emails
NOTIFY_EMAIL=James.T.Platt@gmail.com

# Scoring thresholds (do not change without approval per .cursorrules)
TIER1_EMAIL_THRESHOLD=80
TIER2_EMAIL_THRESHOLD=8
TIER2_TOP_N=10

# USAJobs API requires a User-Agent (your email) per their TOS
USAJOBS_USER_AGENT=James.T.Platt@gmail.com
USAJOBS_API_KEY=
